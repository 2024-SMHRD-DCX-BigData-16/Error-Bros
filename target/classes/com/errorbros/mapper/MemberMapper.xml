<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.errorbors.mapper.MemberMapper">
	
	<!-- 회원가입 -->
	<insert id="memberInsert" parameterType="com.errorbors.entity.MemberDTO">
		insert into tb_member values(#{mem_id}, #{mem_pw}, #{mem_nm}, #{mem_phone}, #{mem_email}, #{mem_birthdate}, #{mem_gender}, #{mem_role}, #{joined_at});
	</insert>

	<!-- 중복아이디 확인 -->
	<select id="idCheck" parameterType="String" resultType="com.errorbros.entity.MemberDTO">
		select * from tb_member where mem_id=#{mem_id};
	</select>
	
	
	<!-- 로그인 -->
	<select id="memberLogIn" parameterType="com.errorbros.entity.MemberDTO">
			select * from tb_member where mem_id=#{mem_id} and mem_pw=#{mem_pw};
	</select>

	

</mapper>
	
